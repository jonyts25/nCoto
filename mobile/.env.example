# Copia este archivo a `.env` en la raíz de /mobile (no subas `.env` al repositorio).
# Expo solo expone al bundle las variables que empiezan por EXPO_PUBLIC_.

# URL del proyecto Supabase (Project Settings → API → Project URL)
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima public (Project Settings → API → anon public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Opcional: slug si desplegaste la Edge Function con otro nombre (default: admin-create-user)
# EXPO_PUBLIC_EDGE_FN_ADMIN_CREATE_USER=admin-create-user

# No pongas aquí la service_role key: en el cliente móvil quedaría expuesta en el bundle.
