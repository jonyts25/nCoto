# Copia a `.env` en la raíz de /bot. El servidor usa la service role solo en backend.

# Supabase (Project Settings → API)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Servidor HTTP
PORT=3000

# Cron de seguimiento paquetería (opcional; ver MVP_STATUS / index.ts del bot)
PACKAGE_FOLLOWUP_TZ=America/Mexico_City
PACKAGE_FOLLOWUP_CRON=59 23 * * *

# Si defines un valor, POST /jobs/paqueteria-followup exige la cabecera x-cron-secret con el mismo valor
CRON_HTTP_SECRET=
