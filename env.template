# =============================================================================
# NCoto — Plantilla de variables locales (NO commitear con valores reales)
# =============================================================================
# Obtén los valores en: Supabase Dashboard → Project Settings → API
#   - Project URL  → SUPABASE_URL / EXPO_PUBLIC_* / NEXT_PUBLIC_*
#   - anon public  → ANON_KEY (solo cliente mobile + web)
#   - service_role → SERVICE_ROLE_KEY (solo bot/.env y Edge Functions en Supabase)
#
# Después de clonar:
#   1. Copia este archivo mentalmente a mobile/.env, web/.env.local y bot/.env
#   2. O ejecuta:  .\scripts\setup-env.ps1   (Windows)  |  ./scripts/setup-env.sh (Mac/Linux)
#   3. Edita cada .env con tus valores reales
# =============================================================================

# --- Compartido (mismo proyecto en los tres clientes) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_solo_backend

# --- Mobile (mobile/.env) — prefijo EXPO_PUBLIC_ obligatorio ---
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
# EXPO_PUBLIC_EDGE_FN_ADMIN_CREATE_USER=admin-create-user

# --- Web (web/.env.local) — prefijo NEXT_PUBLIC_ obligatorio ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# --- Bot (bot/.env) — nunca en mobile/web ---
# SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY (arriba)
PORT=3000
# MESSAGING_PROVIDER=whatsapp_web_js
# MESSAGING_PROVIDER=meta_cloud_api
# META_WHATSAPP_ACCESS_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_WHATSAPP_VERIFY_TOKEN=
# PACKAGE_FOLLOWUP_TZ=America/Mexico_City
# PACKAGE_FOLLOWUP_CRON=59 23 * * *
# CRON_HTTP_SECRET=

